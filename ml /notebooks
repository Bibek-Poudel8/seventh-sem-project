        "\n",
        "def predict_category(description, model, vectorizer, threshold=CONFIDENCE_THRESHOLD):\n",
        "    \"\"\"\n",
        "    Hybrid predictor: keyword rules → ML model → confidence gate.\n",
        "    Returns (category, confidence, method)\n",
        "    \"\"\"\n",
        "    desc_lower = str(description).lower().strip()\n",
        "\n",
        "    # Guard: empty or too short to mean anything\n",
        "    if len(desc_lower) < 3:\n",
        "        return 'Uncategorized', 0.0, 'too_short'\n",
        "\n",
        "    # Step 1: Keyword rule check\n",
        "    for category, keywords in KEYWORD_RULES.items():\n",
        "        if any(kw in desc_lower for kw in keywords):\n",
        "            return category, 1.0, 'rule'\n",
        "\n",
        "    # Step 2: ML model\n",
        "    cleaned    = clean_transaction_description(description)\n",
        "    features   = vectorizer.transform([cleaned])\n",
        "    prediction = model.predict(features)[0]\n",
        "    proba      = model.predict_proba(features)[0]\n",
        "    confidence = max(proba)\n",
        "\n",
        "    # Step 3: Confidence gate — if model is unsure, say so\n",
        "    if confidence < threshold:\n",
        "        return 'Uncategorized', confidence, 'low_confidence'\n",
        "\n",
        "    return prediction, confidence, 'ml'\n",
